{
  "version": "2.0",
  "project": {
    "name": "specweave",
    "version": "1.0.1"
  },
  "pluginAutoLoad": {
    "enabled": true,
    "suggestOnly": false
  },
  "multiProject": {
    "enabled": true
  },
  "billing": {
    "planType": "subscription",
    "monthlyAmount": 200
  },
  "adapters": {
    "default": "claude"
  },
  "repository": {
    "provider": "local"
  },
  "issueTracker": {
    "provider": "jira",
    "domain": "antonabyzov.atlassian.net",
    "projects": [
      { "key": "SWE2E", "id": "10139", "name": "SpecWeave E2E Test" },
      { "key": "WTTC", "id": "10001", "name": "What To Code" }
    ]
  },
  "sync": {
    "enabled": true,
    "preset": "bidirectional",
    "direction": "bidirectional",
    "autoSync": true,
    "provider": "jira",
    "defaultProfile": "jira-swe2e",
    "settings": {
      "canUpsertInternalItems": true,
      "canUpdateExternalItems": true,
      "canUpdateStatus": true,
      "autoSyncOnCompletion": true
    },
    "profiles": {
      "jira-swe2e": {
        "platform": "jira",
        "config": {
          "domain": "antonabyzov.atlassian.net",
          "projectKey": "SWE2E",
          "projectId": "10139"
        }
      },
      "jira-wttc": {
        "platform": "jira",
        "config": {
          "domain": "antonabyzov.atlassian.net",
          "projectKey": "WTTC"
        }
      }
    },
    "github": {
      "enabled": true,
      "owner": "anton-abyzov",
      "repo": "specweave"
    },
    "jira": {
      "enabled": true,
      "domain": "antonabyzov.atlassian.net",
      "projectKey": "SWE2E"
    },
    "ado": {
      "enabled": true,
      "organization": "EasyChamp",
      "project": "SpecWeaveSync"
    }
  },
  "hooks": {
    "post_task_completion": {
      "sync_tasks_md": true,
      "external_tracker_sync": false
    },
    "post_increment_planning": {
      "auto_create_github_issue": true,
      "sync_living_docs": true
    },
    "post_increment_done": {
      "sync_living_docs": true,
      "sync_to_github_project": true,
      "close_github_issue": true
    }
  },
  "auto": {
    "enabled": true,
    "maxRetries": 20,
    "requireTests": true,
    "requireValidation": true,
    "requireJudgeLLM": false,
    "skipQualityGates": false
  },
  "testing": {
    "defaultTestMode": "TDD",
    "tddEnforcement": "strict",
    "defaultCoverageTarget": 90,
    "coverageTargets": {
      "unit": 60,
      "integration": 90,
      "e2e": 100
    }
  },
  "documentation": {
    "directories": [
      ".specweave/docs"
    ],
    "publicSitePath": "repositories/anton-abyzov/specweave/docs-site",
    "preview": {
      "enabled": false,
      "autoInstall": false,
      "port": 3015,
      "openBrowser": true,
      "theme": "default",
      "excludeFolders": [
        "legacy",
        "node_modules"
      ]
    }
  },
  "language": "en",
  "translation": {
    "enabled": false,
    "languages": [
      "en"
    ],
    "primary": "en",
    "method": "manual",
    "preserveFrameworkTerms": true,
    "scope": {
      "livingDocs": false,
      "externalSync": false,
      "incrementSpecs": false
    },
    "keepEnglishOriginals": false
  },
  "lsp": {
    "enabled": true,
    "autoInstallPlugins": true,
    "marketplace": "boostvolt/claude-code-lsps"
  },
  "planning": {
    "deepInterview": {
      "enabled": true,
      "enforcement": "strict",
      "minQuestions": 5,
      "categories": [
        "architecture",
        "integrations",
        "ui-ux",
        "performance",
        "security",
        "edge-cases"
      ]
    }
  },
  "limits": {
    "maxActiveIncrements": 3,
    "hardCap": 25,
    "allowEmergencyInterrupt": true
  },
  "umbrella": {
    "enabled": true,
    "projectName": "specweave-umb",
    "sync": {
      "github": { "owner": "anton-abyzov", "repo": "specweave-umb" },
      "jira": { "projectKey": "SWE2E" },
      "ado": { "organization": "EasyChamp", "project": "SpecWeaveSync" }
    },
    "childRepos": [
      {
        "id": "specweave",
        "path": "repositories/anton-abyzov/specweave",
        "name": "specweave",
        "prefix": "SPE",
        "githubUrl": "https://github.com/anton-abyzov/specweave.git",
        "sync": {
          "github": { "owner": "anton-abyzov", "repo": "specweave" },
          "jira": { "projectKey": "SWE2E" },
          "ado": { "organization": "EasyChamp", "project": "SpecWeaveSync" }
        }
      },
      {
        "id": "vskill",
        "path": "repositories/anton-abyzov/vskill",
        "name": "vskill",
        "prefix": "VSK",
        "githubUrl": "https://github.com/anton-abyzov/vskill.git",
        "sync": {
          "github": { "owner": "anton-abyzov", "repo": "vskill" },
          "jira": { "projectKey": "SWE2E" },
          "ado": { "organization": "EasyChamp", "project": "SpecWeaveSync" }
        }
      },
      {
        "id": "vskill-platform",
        "path": "repositories/anton-abyzov/vskill-platform",
        "name": "vskill-platform",
        "prefix": "VPL",
        "githubUrl": "https://github.com/anton-abyzov/vskill-platform.git",
        "sync": {
          "github": { "owner": "anton-abyzov", "repo": "vskill-platform" },
          "jira": { "projectKey": "SWE2E" },
          "ado": { "organization": "EasyChamp", "project": "SpecWeaveSync" }
        }
      }
    ]
  }
}